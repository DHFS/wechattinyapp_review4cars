/* ============================================
   车评侦探 - 全局样式
   深色主题配置
   ============================================ */

/* 基础重置 - page 作为根元素 */
page, .page, .page-body {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  background-color: #121212 !important;
  
  /* 深色主题配色 */
  --bg-primary: #121212;
  --bg-secondary: #1E1E1E;
  --bg-card: #252525;
  --bg-hover: #2A2A2A;
  
  /* 文字颜色 */
  --text-primary: #FFFFFF;
  --text-secondary: #B0B0B0;
  --text-tertiary: #707070;
  
  /* 强调色 */
  --accent-primary: #FF6B35;
  --accent-secondary: #FF8C42;
  --accent-glow: rgba(255, 107, 53, 0.3);
  
  /* 功能色 */
  --success: #4CAF50;
  --warning: #FFC107;
  --error: #F44336;
  --info: #2196F3;
  
  /* 边框 */
  --border-color: #333333;
  --divider: #2A2A2A;

  /* 全局字体和背景 */
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
  background-color: var(--bg-primary);
  color: var(--text-primary);
  font-size: 14px;
  line-height: 1.6;
  
  /* 全局使用 Flex 布局 */
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

/* 对所有元素应用 border-box */
view, text, image, input, textarea, button, scroll-view {
  box-sizing: border-box;
}

/* 通用容器 - Flex 纵向布局 */
.container {
  display: flex;
  flex-direction: column;
  flex: 1;
  padding: 16px;
}

/* Flex 行布局 */
.flex-row {
  display: flex;
  flex-direction: row;
}

/* Flex 列布局 */
.flex-column {
  display: flex;
  flex-direction: column;
}

/* Flex 居中 */
.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

/* Flex 两端对齐 */
.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* Flex 环绕对齐 */
.flex-around {
  display: flex;
  justify-content: space-around;
  align-items: center;
}

/* Flex 自动填充 */
.flex-1 {
  flex: 1;
}

/* Flex 不换行 */
.flex-nowrap {
  flex-wrap: nowrap;
}

/* Flex 换行 */
.flex-wrap {
  flex-wrap: wrap;
}

/* 文字省略 - 单行 */
.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 文字省略 - 两行 */
.ellipsis-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 卡片样式 */
.card {
  background-color: var(--bg-card);
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
  border: 1px solid var(--border-color);
}

/* 按钮基础样式 */
.btn {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 12px 24px;
  border-radius: 24px;
  font-size: 14px;
  font-weight: 500;
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
  color: #FFFFFF;
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-secondary {
  background-color: var(--bg-secondary);
  color: var(--text-primary);
  border: 1px solid var(--border-color);
}

/* 标签样式 */
.tag {
  display: inline-flex;
  padding: 4px 10px;
  border-radius: 4px;
  font-size: 11px;
  font-weight: 500;
}

.tag-accent {
  background-color: rgba(255, 107, 53, 0.15);
  color: var(--accent-primary);
}

.tag-default {
  background-color: var(--bg-secondary);
  color: var(--text-secondary);
}

/* 分割线 */
.divider {
  height: 1px;
  background-color: var(--divider);
  margin: 16px 0;
}

/* 加载状态 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px;
  color: var(--text-tertiary);
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 20px;
  color: var(--text-tertiary);
}

/* 安全区适配 */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 点击效果 */
.active:active {
  background-color: var(--bg-hover);
  opacity: 0.7;
}

/* 滚动条样式 - 深色模式 */
::-webkit-scrollbar {
  width: 4px;
  height: 4px;
}

::-webkit-scrollbar-track {
  background: var(--bg-secondary);
}

::-webkit-scrollbar-thumb {
  background: var(--border-color);
  border-radius: 2px;
}

::-webkit-scrollbar-thumb:hover {
  background: var(--text-tertiary);
}
