/* 详情页 - 深色风格 */
page {
  background: #121212;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
}

.page {
  padding: 16px;
  padding-bottom: 40px;
  min-height: 100vh;
}

/* 车型封面图 */
.car-hero-image {
  position: relative;
  width: 100%;
  height: 420rpx;
  border-radius: 32rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  background: #1c1b1b;
}

.hero-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.hero-image-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #252525 0%, #1c1b1b 100%);
}

.placeholder-icon {
  font-size: 80rpx;
  opacity: 0.3;
  margin-bottom: 16rpx;
}

.placeholder-text {
  font-size: 28rpx;
  color: #666;
}

.image-edit-hint {
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(8rpx);
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.image-edit-hint text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 页面加载状态 */
.page-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
}

.page-loading .loading-spinner {
  width: 40px;
  height: 40px;
  border: 3px solid #333333;
  border-top-color: #FF6B35;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 16px;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.page-loading .loading-text {
  font-size: 14px;
  color: #666666;
}

/* 头部车型信息 */
.header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: flex-start;
  background: #1A1A1A;
  border-radius: 16px;
  padding: 20px;
  margin-bottom: 16px;
}

.car-basic {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.car-name {
  font-size: 22px;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8px;
}

.car-tags {
  display: flex;
  flex-direction: row;
  gap: 8px;
  margin-bottom: 8px;
}

.tag {
  font-size: 11px;
  font-weight: 500;
  padding: 3px 10px;
  border-radius: 4px;
  color: #FFFFFF;
}

.tag-gray {
  font-size: 11px;
  color: #888888;
  background: #333333;
  padding: 3px 10px;
  border-radius: 4px;
}

.car-price {
  font-size: 14px;
  color: #FF6B35;
  font-weight: 600;
}

.total-score {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-left: 20px;
  border-left: 1px solid #333333;
}

.score-value {
  font-size: 36px;
  font-weight: 800;
  color: #FFD700;
  line-height: 1;
}

.score-label {
  font-size: 11px;
  color: #666666;
  margin-top: 4px;
}

/* 区块样式 */
.section {
  background: #1A1A1A;
  border-radius: 16px;
  padding: 20px;
  margin-bottom: 16px;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 16px;
}

.section-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}

.section-header .section-title {
  margin-bottom: 0;
}

.review-count {
  font-size: 12px;
  color: #666666;
}

/* 雷达图 */
.radar-container {
  width: 100%;
  height: 300px;
  display: flex;
  justify-content: center;
  align-items: center;
}

.radar-canvas {
  width: 280px;
  height: 280px;
}

.radar-legend {
  display: flex;
  justify-content: center;
  margin-top: 12px;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 6px;
}

.legend-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
}

.legend-text {
  font-size: 12px;
  color: #888888;
}

/* 五维评分 - 标签式紧凑布局 */
.dimension-list {
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  gap: 8px;
  overflow-x: auto;
  padding-bottom: 4px;
}

.dimension-tag {
  flex: 1;
  min-width: 60px;
  background: #252525;
  border-radius: 10px;
  padding: 12px 8px 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  overflow: hidden;
}

.tag-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 8px;
  z-index: 1;
}

.tag-name {
  font-size: 11px;
  color: #AAAAAA;
  margin-bottom: 4px;
  text-align: center;
  white-space: nowrap;
}

.tag-score {
  font-size: 24px;
  font-weight: 800;
  line-height: 1;
}

/* 权重色条 */
.tag-weight-bar {
  height: 3px;
  border-radius: 2px;
  margin-bottom: 4px;
  opacity: 0.8;
}

.tag-weight-text {
  font-size: 9px;
  color: #666666;
  white-space: nowrap;
}

/* 评分滑块区域 */
.rating-list {
  display: flex;
  flex-direction: column;
  gap: 20px;
  margin-bottom: 20px;
}

.rating-item {
  display: flex;
  flex-direction: column;
}

.rating-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.rating-name {
  font-size: 14px;
  color: #CCCCCC;
}

.rating-value-box {
  background: #333333;
  border-radius: 6px;
  padding: 4px 12px;
}

.rating-value {
  font-size: 15px;
  font-weight: 700;
  color: #FFFFFF;
}

.rating-value.unrated {
  color: #666666;
  font-size: 13px;
}

.rating-slider {
  margin: 0;
}

.rating-desc {
  font-size: 11px;
  color: #555555;
  margin-top: -4px;
}

/* 计算得分 */
.calculated-score {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  background: #252525;
  border-radius: 12px;
  padding: 16px 20px;
  margin-bottom: 16px;
}

.calculated-score.unrated {
  opacity: 0.6;
}

.calc-label {
  font-size: 14px;
  color: #AAAAAA;
}

.calc-value {
  font-size: 32px;
  font-weight: 800;
  color: #FFFFFF;
}

/* 评价输入 */
.comment-input {
  width: 100%;
  min-height: 200px;
  max-height: 300px;
  background: #252525;
  border-radius: 12px;
  padding: 16px;
  font-size: 15px;
  line-height: 1.8;
  color: #FFFFFF;
  box-sizing: border-box;
  margin-bottom: 8px;
}

.comment-input::placeholder {
  color: #555555;
}

.char-count {
  font-size: 11px;
  color: #555555;
  text-align: right;
  display: block;
  margin-bottom: 16px;
}

/* 已评价提示 */
.reviewed-tip {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 20px 0;
  margin-bottom: 16px;
}

.tip-icon {
  width: 24px;
  height: 24px;
  background: #4CAF50;
  border-radius: 50%;
  color: #FFFFFF;
  font-size: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tip-text {
  font-size: 15px;
  color: #AAAAAA;
}

.edit-review-btn {
  width: 100%;
  height: 48px;
  background: #333333;
  color: #FFFFFF;
  font-size: 15px;
  font-weight: 600;
  border-radius: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid #444444;
}

.edit-review-btn::after {
  border: none;
}

.edit-review-btn:active {
  background: #444444;
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  height: 48px;
  background: linear-gradient(135deg, #FF6B35, #FF8C42);
  color: #FFFFFF;
  font-size: 15px;
  font-weight: 600;
  border-radius: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.submit-btn::after {
  border: none;
}

.submit-btn[disabled] {
  opacity: 0.6;
}

/* 已评价提示区域 */
.has-reviewed-section {
  background: #1A1A1A;
  border-radius: 12px;
  padding: 20px;
}

.has-reviewed-box {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  margin-bottom: 16px;
  background: rgba(255, 107, 53, 0.1);
  border: 1px solid rgba(255, 107, 53, 0.3);
  border-radius: 10px;
  padding: 16px;
}

.has-reviewed-icon {
  width: 32px;
  height: 32px;
  background: linear-gradient(135deg, #FF6B35, #FF8C42);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 16px;
  font-weight: bold;
  margin-right: 12px;
  flex-shrink: 0;
}

.has-reviewed-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.has-reviewed-title {
  font-size: 15px;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 4px;
}

.has-reviewed-desc {
  font-size: 12px;
  color: #888888;
  line-height: 1.4;
}

.edit-btn {
  background: linear-gradient(135deg, #4CAF50, #45a049);
}

.submit-tips {
  display: block;
  text-align: center;
  font-size: 11px;
  color: #666666;
  margin-top: 10px;
}

/* 编辑区域 */
.cancel-edit {
  font-size: 13px;
  color: #888888;
  padding: 4px 8px;
}

.cancel-edit:active {
  color: #FFFFFF;
}

/* 评价列表 */
.review-list {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.review-item {
  background: #252525;
  border-radius: 12px;
  padding: 18px;
  margin-bottom: 12px;
}

.review-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 12px;
}

.review-avatar {
  width: 40px;
  height: 40px;
  border-radius: 20px;
  margin-right: 12px;
  background: #333333;
}

.review-user {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.review-name {
  font-size: 14px;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 2px;
}

.review-time {
  font-size: 11px;
  color: #666666;
}

.review-score {
  display: flex;
  flex-direction: row;
  align-items: baseline;
}

.review-score-value {
  font-size: 24px;
  font-weight: 700;
  color: #FFD700;
}

.review-score-unit {
  font-size: 11px;
  color: #FFD700;
  margin-left: 2px;
}

.review-content {
  margin-bottom: 8px;
  padding-bottom: 16px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.review-text {
  font-size: 14px;
  color: #CCCCCC;
  line-height: 1.7;
}

.expand-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1px solid rgba(255, 255, 255, 0.05);
}

.expand-btn text {
  font-size: 13px;
  color: #FF6B35;
}

.expand-icon {
  margin-left: 4px;
  font-size: 12px;
}

.review-dimensions {
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  gap: 4px;
  margin-top: 12px;
  margin-bottom: 12px;
  justify-content: space-between;
}

.review-dimensions {
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  gap: 4px;
  margin-top: 4px;
  margin-bottom: 12px;
  justify-content: space-between;
}

.review-dim {
  font-size: 11px;
  background: rgba(51, 51, 51, 0.5);
  padding: 3px 6px;
  border-radius: 4px;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 2px;
  border: 1px solid;
  line-height: 1;
  white-space: nowrap;
  flex: 1;
  min-width: 0;
}

.review-dim .dim-name {
  opacity: 0.8;
}

.review-dim .dim-score {
  font-weight: 600;
}

/* 评价操作按钮 */
.review-actions {
  display: flex;
  flex-direction: row;
  justify-content: flex-end;
  align-items: center;
  gap: 8px;
  padding-top: 8px;
  border-top: 1px solid #333333;
}

.action-btn {
  font-size: 12px;
  padding: 4px 8px;
}

.action-btn.edit {
  color: #4CAF50;
}

.action-btn.delete {
  color: #FF5252;
}

.action-divider {
  font-size: 12px;
  color: #444444;
}

/* ============================================
   完善资料弹窗
   ============================================ */

.profile-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.profile-modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  backdrop-filter: blur(4px);
}

.modal-content {
  position: relative;
  width: 80%;
  max-width: 320px;
  background: #1A1A1A;
  border-radius: 16px;
  overflow: hidden;
  transform: scale(0.9);
  transition: transform 0.3s ease;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.profile-modal.show .modal-content {
  transform: scale(1);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px 20px 0;
}

.modal-title {
  font-size: 18px;
  font-weight: 600;
  color: #FFFFFF;
}

.modal-close {
  font-size: 24px;
  color: #666666;
  padding: 0 4px;
  line-height: 1;
}

.modal-body {
  padding: 20px;
}

.modal-desc {
  display: block;
  font-size: 13px;
  color: #888888;
  margin-bottom: 24px;
  text-align: center;
}

.profile-item {
  display: flex;
  align-items: center;
  margin-bottom: 20px;
}

.item-label {
  width: 60px;
  font-size: 15px;
  color: #CCCCCC;
  flex-shrink: 0;
}

/* 头像选择按钮 */
.avatar-btn {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  padding: 0;
  margin: 0;
  background: #2A2A2A;
  border: 2px dashed #444444;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.avatar-btn::after {
  border: none;
}

.avatar-preview {
  width: 76px;
  height: 76px;
  border-radius: 50%;
  background: #2A2A2A;
}

.avatar-hint {
  position: absolute;
  bottom: 8px;
  font-size: 11px;
  color: #888888;
  background: rgba(0, 0, 0, 0.6);
  padding: 2px 8px;
  border-radius: 10px;
}

/* 昵称输入框 */
.nickname-input {
  flex: 1;
  height: 44px;
  background: #2A2A2A;
  border-radius: 8px;
  padding: 0 16px;
  font-size: 15px;
  color: #FFFFFF;
  border: 1px solid #333333;
}

.nickname-input:focus {
  border-color: #FF6B35;
}

.modal-footer {
  padding: 0 20px 20px;
}

.confirm-btn {
  width: 100%;
  height: 44px;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C42 100%);
  border-radius: 22px;
  font-size: 15px;
  font-weight: 500;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.confirm-btn::after {
  border: none;
}

.confirm-btn.disabled {
  background: #444444;
  color: #888888;
}


/* 撰写评价入口区域 */
.write-review-section {
  background: linear-gradient(135deg, #1A1A1A 0%, #252525 100%);
  border-radius: 16px;
  padding: 24px 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 1px solid #2A2A2A;
}

.write-review-content {
  text-align: center;
  margin-bottom: 16px;
}

.write-review-title {
  display: block;
  font-size: 18px;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 6px;
}

.write-review-desc {
  display: block;
  font-size: 13px;
  color: #888888;
}

.write-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8px;
  padding: 0 32px;
  width: auto;
  min-width: 160px;
}

.btn-icon {
  font-size: 16px;
}
