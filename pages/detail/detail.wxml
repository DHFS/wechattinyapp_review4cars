<view class="page">
  <!-- 页面加载中 -->
  <view wx:if="{{pageLoading}}" class="page-loading">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 页面内容 -->
  <block wx:else>
  <!-- 车型封面图 -->
  <view class="car-hero-image" bindlongpress="onImageLongPress">
    <image 
      wx:if="{{carInfo.imageUrl}}" 
      class="hero-image" 
      src="{{carInfo.imageUrl}}" 
      mode="aspectFill"
    />
    <view wx:else class="hero-image-placeholder">
      <text class="placeholder-icon">🚗</text>
      <text class="placeholder-text">暂无官方图片</text>
    </view>
    <view class="image-edit-hint" wx:if="{{showEditHint}}">
      <text>长按可编辑图片</text>
    </view>
  </view>

  <!-- 车型头部信息 -->
  <view class="header">
    <view class="car-basic">
      <text class="car-name">{{carInfo.brand}} {{carInfo.model}}</text>
      <view class="car-tags">
        <text class="tag" style="background: {{carInfo.tagColor}};">{{carInfo.powerType}}</text>
        <text class="tag-gray">{{carInfo.year}}</text>
      </view>
      <text class="car-price">{{carInfo.price}}</text>
    </view>
    <view class="total-score">
      <text class="score-value">{{carInfo.avgScore}}</text>
      <text class="score-label">综合得分</text>
    </view>
  </view>

  <!-- 五维雷达图 - 带分数标签 -->
  <view class="section">
    <view class="section-title">五维雷达图</view>
    <view class="radar-container">
      <canvas 
        type="2d" 
        id="radarCanvas" 
        class="radar-canvas"
        bindtouchstart="onRadarTouch"
      ></canvas>
    </view>
    <view class="radar-legend">
      <view class="legend-item">
        <view class="legend-dot" style="background: #FF6B35;"></view>
        <text class="legend-text">全网平均分</text>
      </view>
    </view>
  </view>

  <!-- 五维评分 - 标签式紧凑布局 -->
  <view class="section">
    <view class="section-title">五维评分</view>
    <view class="dimension-list">
      <view class="dimension-tag" wx:for="{{dimensions}}" wx:key="name">
        <view class="tag-content">
          <text class="tag-name">{{item.name}}</text>
          <text class="tag-score" style="color: {{item.color}};">{{item.score}}</text>
        </view>
        <view class="tag-weight-bar" style="width: {{item.weight}}; background: {{item.color}};"></view>
        <text class="tag-weight-text">{{item.weight}}</text>
      </view>
    </view>
  </view>

  <!-- 已评价提示 - 用户已评价过此车型 -->
  <view class="section has-reviewed-section" wx:if="{{hasReviewed && !editingReview}}">
    <view class="has-reviewed-box">
      <text class="has-reviewed-icon">✓</text>
      <view class="has-reviewed-content">
        <text class="has-reviewed-title">您已评价过此车型</text>
        <text class="has-reviewed-desc">您可以修改自己的评价，每位用户只能评价一次</text>
      </view>
    </view>
    <button class="submit-btn edit-btn" bindtap="startEditFromButton">
      修改我的评价
    </button>
  </view>

  <!-- 撰写评价入口 -->
  <view class="section write-review-section" wx:if="{{!hasReviewed}}">
    <view class="write-review-content">
      <text class="write-review-title">分享您的用车体验</text>
      <text class="write-review-desc">撰写评价，帮助更多车友了解这款车</text>
    </view>
    <button class="submit-btn write-btn" bindtap="submitReview">
      <text class="btn-icon">✎</text>
      <text>撰写评价</text>
    </button>
  </view>

  <!-- 用户评价列表 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">用户评价</text>
      <text class="review-count">{{reviews.length}}条</text>
    </view>
    
    <view class="review-list">
      <view class="review-item" wx:for="{{reviews}}" wx:key="_id">
        <view class="review-header">
          <image class="review-avatar" src="{{item.userAvatar || 'https://mmbiz.qpic.cn/mmbiz/icTdbqWNOwNRna42FI242Lcia07jQodd2FJGIYQfG0LAJGFxM4FbnQP6yfMxBgJ0F3YRqJCJ1aPAK2dQagdusBZg/0'}}" mode="aspectFill"/>
          <view class="review-user">
            <text class="review-name">{{item.userNickname || '匿名用户'}}</text>
            <text class="review-time">{{item.time}}</text>
          </view>
          <view class="review-score">
            <text class="review-score-value">{{item.totalScore}}</text>
            <text class="review-score-unit">分</text>
          </view>
        </view>
        
        <view class="review-content">
          <text class="review-text">{{item.displayComment}}</text>
          <view 
            class="expand-btn" 
            wx:if="{{item.isLongComment}}"
            data-index="{{index}}"
            bindtap="toggleComment"
          >
            <text>{{item.isExpanded ? '收起' : '展开'}}</text>
            <text class="expand-icon">{{item.isExpanded ? '↑' : '↓'}}</text>
          </view>
        </view>
        
        <view class="review-dimensions">
          <view class="review-dim" wx:for="{{item.dimensions}}" wx:key="name" wx:for-item="dim" style="color: {{dim.color}}; border-color: {{dim.color}};">
            <text class="dim-name">{{dim.name}}</text>
            <text class="dim-score">{{dim.score}}</text>
          </view>
        </view>

        <!-- 操作按钮（仅当前用户显示） -->
        <view class="review-actions" wx:if="{{item.isOwner}}">
          <text class="action-btn edit" bindtap="startEdit" data-id="{{item._id}}">编辑</text>
          <text class="action-divider">|</text>
          <text class="action-btn delete" bindtap="deleteReview" data-id="{{item._id}}">删除</text>
        </view>
      </view>
    </view>
  </view>
  </block>

  <!-- 完善资料弹窗 -->
  <view class="profile-modal {{showProfileModal ? 'show' : ''}}" wx:if="{{showProfileModal}}">
    <view class="modal-mask" bindtap="closeProfileModal"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">完善资料</text>
        <text class="modal-close" bindtap="closeProfileModal">×</text>
      </view>
      
      <view class="modal-body">
        <text class="modal-desc">请设置您的头像和昵称，用于展示在评价中</text>
        
        <!-- 头像选择 -->
        <view class="profile-item">
          <text class="item-label">头像</text>
          <button 
            class="avatar-btn" 
            open-type="chooseAvatar" 
            bind:chooseavatar="onChooseAvatar"
          >
            <image 
              class="avatar-preview" 
              src="{{tempAvatarUrl || 'https://mmbiz.qpic.cn/mmbiz/icTdbqWNOwNRna42FI242Lcia07jQodd2FJGIYQfG0LAJGFxM4FbnQP6yfMxBgJ0F3YRqJCJ1aPAK2dQagdusBZg/0'}}" 
              mode="aspectFill"
            />
            <text class="avatar-hint" wx:if="{{!tempAvatarUrl}}">点击选择</text>
          </button>
        </view>
        
        <!-- 昵称输入 -->
        <view class="profile-item">
          <text class="item-label">昵称</text>
          <input 
            class="nickname-input" 
            type="nickname"
            placeholder="请输入昵称"
            value="{{tempNickname}}"
            bind:input="onNicknameInput"
            bind:blur="onNicknameChange"
          />
        </view>
      </view>
      
      <view class="modal-footer">
        <button class="confirm-btn {{!tempAvatarUrl || !tempNickname ? 'disabled' : ''}}" bindtap="confirmProfile">
          确认并提交
        </button>
      </view>
    </view>
  </view>
</view>
