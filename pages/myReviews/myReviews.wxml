<view class="page">
  <!-- 未登录状态 - 游客模式 -->
  <view wx:if="{{!isLoggedIn}}" class="guest-mode">
    <view class="guest-header">
      <view class="guest-avatar">
        <text class="guest-icon">👤</text>
      </view>
      <text class="guest-title">游客模式</text>
      <text class="guest-desc">登录后即可提交评价和管理个人数据</text>
      <button class="login-btn-primary" bindtap="handleLogin">立即登录</button>
    </view>
    
    <view class="guest-features">
      <view class="feature-item">
        <text class="feature-icon">🚗</text>
        <text class="feature-text">浏览车型排行榜</text>
      </view>
      <view class="feature-item">
        <text class="feature-icon">📊</text>
        <text class="feature-text">查看五维雷达图</text>
      </view>
      <view class="feature-item">
        <text class="feature-icon">💬</text>
        <text class="feature-text">阅读真实评价</text>
      </view>
    </view>
    
    <view class="guest-hint">
      <text>登录后可享受更多功能：</text>
      <text class="hint-list">• 提交车型评价</text>
      <text class="hint-list">• 管理历史评价</text>
      <text class="hint-list">• 参与车型排行</text>
    </view>
  </view>

  <!-- 已登录状态 - 正常展示 -->
  <block wx:else>
    <!-- 用户资料头部 - 居中显示 -->
    <view class="user-profile-header">
      <image class="user-avatar-large" src="{{displayUserAvatar || 'https://mmbiz.qpic.cn/mmbiz/icTdbqWNOwNRna42FI242Lcia07jQodd2FJGIYQfG0LAJGFxM4FbnQP6yfMxBgJ0F3YRqJCJ1aPAK2dQagdusBZg/0'}}" mode="aspectFill" />
      <text class="user-name-large">{{userName}}</text>
    </view>

    <!-- 主体内容区 -->
    <scroll-view class="content-scroll" scroll-y="true">

      <!-- 我的评价板块 -->
      <view class="section-block">
        <view class="section-header">
          <view class="section-icon icon-review"></view>
          <text class="section-title">我的评价</text>
        </view>
        
        <!-- 加载中 -->
        <view wx:if="{{loading && reviews.length === 0}}" class="loading-state">
          <view class="loading-spinner"></view>
          <text class="loading-text">加载中...</text>
        </view>

        <!-- 空状态 -->
        <view wx:elif="{{!loading && reviews.length === 0}}" class="empty-state-small">
          <text class="empty-icon-small">📝</text>
          <text class="empty-text">暂无评价记录</text>
          <text class="empty-hint">快去首页发现心仪车型吧</text>
        </view>

        <!-- 评价列表 -->
        <view wx:else class="review-list-compact">
          <view 
            wx:for="{{reviews}}" 
            wx:key="_id"
            class="review-card-compact"
            data-carid="{{item.carId}}"
            data-canopen="{{item.canOpenDetail}}"
            bindtap="goCarDetail"
          >
            <view class="compact-left">
              <view class="compact-title-row">
                <text class="compact-car">{{item.brand}} {{item.modelName}}</text>
                <text class="review-status-chip {{item.statusType}}">{{item.statusLabel}}</text>
              </view>
              <text class="compact-score">{{item.myScore}}分 · {{item.time}}</text>
              <text class="compact-status-desc" wx:if="{{item.statusDesc}}">{{item.statusDesc}}</text>
            </view>
            <view class="compact-actions" catchtap="preventBubble">
              <text
                class="compact-btn {{!item.canEdit ? 'disabled' : ''}}"
                data-carid="{{item.carId}}"
                data-canopen="{{item.canOpenDetail}}"
                catchtap="goCarDetail"
              >{{item.canEdit ? '修改' : (item.statusType === 'rejected' ? '未通过' : '审核中')}}</text>
              <text class="compact-btn delete" data-reviewid="{{item._id}}" data-carid="{{item.carId}}" catchtap="deleteReview">删除</text>
            </view>
          </view>

          <view class="view-all-btn" bindtap="viewAllReviews" wx:if="{{allReviews.length > 0}}">
            <text>历史评价</text>
            <text class="arrow">›</text>
          </view>
        </view>
      </view>

      <view class="section-block">
        <view class="section-header expandable" bindtap="toggleSection" data-section="aboutUs">
          <view class="section-left">
            <view class="section-icon icon-about"></view>
            <text class="section-title">关于我们</text>
          </view>
          <view class="expand-icon">
            <text>{{aboutUsExpanded ? '↑' : '↓'}}</text>
          </view>
        </view>
        <view class="about-us-content" wx:if="{{aboutUsExpanded}}">
          <view class="about-us-group">
            <text class="about-us-group-title">关于车评侦探</text>
            <view class="about-content merged">
              <text class="about-text">车评侦探是一款基于真实用户评价的微信小程序，致力于为车友提供客观、全面的车型评分参考。</text>
              <view class="about-features">
                <view class="feature-item">
                  <text class="feature-dot">•</text>
                  <text class="feature-text">五维评分系统：动力、操控、空间、辅驾、其他</text>
                </view>
                <view class="feature-item">
                  <text class="feature-dot">•</text>
                  <text class="feature-text">实时排行榜：按综合评分排序展示热门车型</text>
                </view>
                <view class="feature-item">
                  <text class="feature-dot">•</text>
                  <text class="feature-text">真实评价：基于车主真实用车体验的口碑分享</text>
                </view>
              </view>
            </view>
          </view>

          <view class="about-us-group">
            <text class="about-us-group-title">联系我们</text>
            <view class="contact-content merged">
              <text class="contact-desc">如有问题或建议，欢迎通过微信联系我们</text>
              <view class="contact-item">
                <view class="contact-label">微信号</view>
                <view class="contact-value">
                  <text class="contact-text">340250808</text>
                </view>
              </view>
            </view>
          </view>

          <view class="about-us-group">
            <text class="about-us-group-title">账号管理</text>
            <view class="account-content merged">
              <view class="account-info">
                <view class="user-info-row">
                  <image wx:if="{{displayUserAvatar}}" class="user-avatar" src="{{displayUserAvatar}}" mode="aspectFill"/>
                  <view class="user-meta">
                    <text class="user-name">{{userName}}</text>
                  </view>
                </view>
                <button class="logout-btn" bindtap="handleLogout">退出登录</button>
              </view>
            </view>
          </view>

          <view class="about-us-group" wx:if="{{isAdmin}}">
            <text class="about-us-group-title">管理入口</text>
            <view class="admin-entry-card admin-entry-card-inline" bindtap="goAdminCars">
              <view class="admin-entry-copy">
                <text class="admin-entry-title">车型审核台</text>
                <text class="admin-entry-desc">查看待审核车型，快速通过或拒绝用户提交内容。</text>
              </view>
              <text class="admin-entry-arrow">›</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 底部留白（为TabBar留出空间） -->
      <view class="bottom-space"></view>
    </scroll-view>
  </block>

  <!-- 完善资料弹窗 -->
  <view class="profile-modal {{showProfileModal ? 'show' : ''}}" wx:if="{{showProfileModal}}">
    <view class="modal-mask" bindtap="closeProfileModal"></view>
    <view class="modal-content">
      <view class="modal-title">完善资料</view>
      <text class="modal-desc">请设置您的头像和昵称</text>
      
      <view class="avatar-section">
        <button class="avatar-wrapper" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
          <image class="avatar-img" src="{{tempAvatarUrl || 'https://mmbiz.qpic.cn/mmbiz/icTdbqWNOwNRna42FI242Lcia07jQodd2FJGIYQfG0LAJGFxM4FbnQP6yfMxBgJ0F3YRqJCJ1aPAK2dQagdusBZg/0'}}" mode="aspectFill"/>
          <text class="avatar-hint">点击选择头像</text>
        </button>
      </view>
      
      <view class="nickname-section">
        <text class="input-label">昵称</text>
        <input 
          type="nickname"
          class="nickname-input" 
          placeholder="请输入昵称"
          value="{{tempNickname}}"
          bindinput="onNicknameInput"
        />
      </view>
      
      <view class="modal-actions">
        <button class="modal-btn cancel" bindtap="closeProfileModal">取消</button>
        <button class="modal-btn confirm" bindtap="confirmProfile">确定</button>
      </view>
    </view>
  </view>
</view>
