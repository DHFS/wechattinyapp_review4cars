/* ============================================
   我的评价页面 - Editorial Industrialism 设计规范
   ============================================ */

page {
  background: #131313;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', 'Inter', sans-serif;
  -webkit-font-smoothing: antialiased;
}

.page {
  min-height: 100vh;
  padding: 0 16px 40px;
}

/* ============================================
   头部统计 - 大数字卡片风格
   ============================================ */
.header {
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: center;
  padding: 40rpx 0 32rpx;
  gap: 60rpx;
}

.stat-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.stat-num {
  font-size: 72rpx;
  font-weight: 800;
  color: #ff6b35;
  line-height: 1;
  letter-spacing: -2rpx;
}

.stat-label {
  font-size: 26rpx;
  color: rgba(225, 191, 181, 0.7);
  font-weight: 500;
}

.stat-divider {
  width: 2rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.08);
}

/* ============================================
   可滚动内容区
   ============================================ */
.content-scroll {
  flex: 1;
  height: calc(100vh - 200rpx);
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

/* ============================================
   板块区块 - 大圆角卡片
   ============================================ */
.section-block {
  background: #1c1b1b;
  border-radius: 32rpx;
  margin-bottom: 32rpx;
  overflow: hidden;
}

/* ============================================
   板块头部 - 无分割线设计
   ============================================ */
.section-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 32rpx;
}

.section-header.expandable {
  justify-content: space-between;
  cursor: pointer;
}

.section-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.section-icon {
  width: 40rpx;
  height: 40rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 评价图标 */
.icon-review::before {
  content: '';
  position: absolute;
  left: 6rpx;
  bottom: 6rpx;
  width: 10rpx;
  height: 18rpx;
  background: #ff6b35;
  border-radius: 2rpx;
}

.icon-review::after {
  content: '';
  position: absolute;
  right: 6rpx;
  bottom: 6rpx;
  width: 10rpx;
  height: 26rpx;
  background: #ff6b35;
  border-radius: 2rpx;
}

/* 关于图标 */
.icon-about {
  border: 3rpx solid #ff6b35;
  border-radius: 50%;
}

.icon-about::before {
  content: '';
  position: absolute;
  top: 8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 6rpx;
  height: 6rpx;
  background: #ff6b35;
  border-radius: 50%;
}

.icon-about::after {
  content: '';
  position: absolute;
  bottom: 6rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 4rpx;
  height: 12rpx;
  background: #ff6b35;
}

/* 帮助图标 */
.icon-help {
  border: 3rpx solid #ff6b35;
  border-radius: 50%;
}

.icon-help::before {
  content: '?';
  font-size: 24rpx;
  color: #ff6b35;
  font-weight: bold;
}

/* 联系图标 */
.icon-contact {
  border: 3rpx solid #ff6b35;
  border-radius: 50%;
}

.icon-contact::before {
  content: '';
  position: absolute;
  top: 8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 10rpx;
  height: 10rpx;
  border: 3rpx solid #ff6b35;
  border-radius: 50%;
  background: transparent;
}

.icon-contact::after {
  content: '';
  position: absolute;
  bottom: 6rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 20rpx;
  height: 10rpx;
  border: 3rpx solid #ff6b35;
  border-top: none;
  border-radius: 0 0 10rpx 10rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #e5e2e1;
  letter-spacing: -0.3px;
}

.expand-icon {
  font-size: 28rpx;
  color: rgba(225, 191, 181, 0.5);
  padding: 8rpx;
}

/* ============================================
   加载状态
   ============================================ */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 4rpx solid #2a2a2a;
  border-top-color: #ff6b35;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 32rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: rgba(229, 226, 225, 0.6);
}

/* ============================================
   空状态
   ============================================ */
.empty-state-small {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
}

.empty-icon-small {
  font-size: 64rpx;
  margin-bottom: 16rpx;
  opacity: 0.8;
}

.empty-text {
  font-size: 30rpx;
  color: #e5e2e1;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: rgba(225, 191, 181, 0.5);
}

/* ============================================
   紧凑评价列表 - 无分割线设计
   ============================================ */
.review-list-compact {
  padding: 0 32rpx;
}

.review-card-compact {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0;
  /* 使用间距代替分割线 */
}

.review-card-compact:not(:last-child) {
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.compact-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.compact-car {
  font-size: 30rpx;
  color: #e5e2e1;
  font-weight: 600;
  letter-spacing: -0.3px;
}

.compact-score {
  font-size: 26rpx;
  color: rgba(225, 191, 181, 0.6);
}

.compact-actions {
  display: flex;
  flex-direction: row;
  gap: 24rpx;
}

.compact-btn {
  font-size: 26rpx;
  color: #ff6b35;
  padding: 8rpx 16rpx;
  font-weight: 500;
}

.compact-btn.delete {
  color: #ff5252;
}

/* ============================================
   加载更多
   ============================================ */
.load-more-small {
  text-align: center;
  padding: 32rpx;
  color: rgba(229, 226, 225, 0.4);
  font-size: 26rpx;
}

.load-more-small.no-more {
  color: rgba(229, 226, 225, 0.3);
}

/* ============================================
   查看全部按钮
   ============================================ */
.view-all-btn {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 28rpx;
  margin: 16rpx 32rpx 32rpx;
  background: rgba(255, 107, 53, 0.1);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 107, 53, 0.3);
}

.view-all-btn text:first-child {
  font-size: 28rpx;
  color: #ff6b35;
  font-weight: 600;
}

.view-all-btn .arrow {
  font-size: 36rpx;
  color: #ff6b35;
  margin-left: 12rpx;
  line-height: 1;
}

/* ============================================
   关于内容
   ============================================ */
.about-content {
  padding: 0 32rpx 32rpx;
}

.about-text {
  font-size: 28rpx;
  color: rgba(229, 226, 225, 0.8);
  line-height: 1.6;
  margin-bottom: 24rpx;
  display: block;
}

.about-features {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.feature-item {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 12rpx;
}

.feature-dot {
  font-size: 28rpx;
  color: #ff6b35;
  line-height: 1.4;
}

.feature-text {
  font-size: 26rpx;
  color: rgba(225, 191, 181, 0.7);
  line-height: 1.4;
  flex: 1;
}

/* ============================================
   帮助内容
   ============================================ */
.help-content {
  padding: 0 32rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.help-item {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
}

.help-step {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff6b35 0%, #ff8c42 100%);
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 26rpx;
  color: #fff;
  font-weight: 700;
  flex-shrink: 0;
}

.help-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.help-title {
  font-size: 28rpx;
  color: #e5e2e1;
  font-weight: 600;
}

.help-desc {
  font-size: 24rpx;
  color: rgba(225, 191, 181, 0.6);
  line-height: 1.5;
}

/* ============================================
   联系内容
   ============================================ */
.contact-content {
  padding: 0 32rpx 32rpx;
}

.contact-desc {
  font-size: 26rpx;
  color: rgba(225, 191, 181, 0.6);
  margin-bottom: 24rpx;
  display: block;
}

.contact-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
}

.contact-label {
  font-size: 28rpx;
  color: rgba(225, 191, 181, 0.6);
  margin-right: 32rpx;
}

.contact-value {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.contact-value text:first-child {
  font-size: 32rpx;
  color: #e5e2e1;
  font-weight: 600;
  letter-spacing: 1px;
}

.copy-hint {
  font-size: 22rpx;
  color: #ff6b35;
  background: rgba(255, 107, 53, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-weight: 500;
}

/* ============================================
   底部留白
   ============================================ */
.bottom-space {
  height: calc(140rpx + env(safe-area-inset-bottom));
  min-height: 180rpx;
}
