/* ============================================
   我的评价页面 - Editorial Industrialism 设计规范
   ============================================ */

page {
  background: #131313;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', 'Inter', sans-serif;
  -webkit-font-smoothing: antialiased;
}

.page {
  min-height: 100vh;
  padding: 0 16px 40px;
}

/* ============================================
   游客模式 - 未登录状态
   ============================================ */
.guest-mode {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  min-height: 80vh;
}

.guest-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.guest-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2a2a2a 0%, #1c1b1b 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  border: 2rpx solid rgba(255, 107, 53, 0.2);
}

.guest-icon {
  font-size: 80rpx;
  opacity: 0.6;
}

.guest-title {
  font-family: "Space Grotesk", "PingFang SC", sans-serif;
  font-size: 40rpx;
  font-weight: 700;
  color: #e5e2e1;
  margin-bottom: 16rpx;
}

.guest-desc {
  font-size: 28rpx;
  color: rgba(225, 191, 181, 0.6);
  margin-bottom: 40rpx;
  text-align: center;
}

.login-btn-primary {
  width: 400rpx;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.06);
  color: rgba(225, 191, 181, 0.78);
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(225, 191, 181, 0.12);
}

.login-btn-primary::after {
  border: none;
}

.guest-features {
  display: flex;
  flex-direction: row;
  justify-content: center;
  gap: 40rpx;
  margin-bottom: 60rpx;
  width: 100%;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.feature-icon {
  font-size: 48rpx;
}

.feature-text {
  font-size: 24rpx;
  color: rgba(225, 191, 181, 0.7);
}

.guest-hint {
  background: rgba(255, 107, 53, 0.08);
  border-radius: 24rpx;
  padding: 32rpx 40rpx;
  width: 100%;
}

.guest-hint text {
  display: block;
  font-size: 26rpx;
  color: rgba(225, 191, 181, 0.8);
  margin-bottom: 16rpx;
}

.hint-list {
  font-size: 24rpx;
  color: rgba(225, 191, 181, 0.6);
  margin-bottom: 8rpx;
  padding-left: 16rpx;
}

/* ============================================
   用户资料头部 - 居中显示
   ============================================ */
.user-profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0 32rpx;
}

.user-avatar-large {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 107, 53, 0.3);
  margin-bottom: 20rpx;
  background: #2a2a2a;
}

.user-name-large {
  font-family: "Space Grotesk", "PingFang SC", sans-serif;
  font-size: 36rpx;
  font-weight: 600;
  color: #e5e2e1;
  letter-spacing: 1rpx;
}

/* ============================================
   头部统计 - 大数字卡片风格
   ============================================ */
.header {
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: center;
  padding: 24rpx 0 32rpx;
  gap: 60rpx;
}

.stat-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.stat-card.clickable {
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 107, 53, 0.06);
}

.stat-num {
  font-size: 72rpx;
  font-weight: 800;
  color: #ff6b35;
  line-height: 1;
  letter-spacing: -2rpx;
}

.stat-label {
  font-size: 26rpx;
  color: rgba(225, 191, 181, 0.7);
  font-weight: 500;
}

.stat-divider {
  width: 2rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.08);
}

/* ============================================
   可滚动内容区
   ============================================ */
.content-scroll {
  flex: 1;
  height: calc(100vh - 200rpx);
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

/* ============================================
   板块区块 - 大圆角卡片
   ============================================ */
.section-block {
  background: #1c1b1b;
  border-radius: 32rpx;
  margin-bottom: 32rpx;
  overflow: hidden;
}

.admin-entry-card {
  margin: 0 32rpx 32rpx;
  padding: 28rpx 28rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(225, 191, 181, 0.1);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.admin-entry-card-inline {
  margin: 0;
}

.admin-entry-copy {
  flex: 1;
  padding-right: 24rpx;
}

.admin-entry-title {
  font-family: "Space Grotesk", "PingFang SC", sans-serif;
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #EDE8E6;
  margin-bottom: 8rpx;
}

.admin-entry-desc {
  display: block;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(225, 191, 181, 0.68);
}

.admin-entry-arrow {
  font-size: 44rpx;
  color: rgba(225, 191, 181, 0.68);
}

/* ============================================
   板块头部 - 无分割线设计
   ============================================ */
.section-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 32rpx;
}

.section-header.expandable {
  justify-content: space-between;
  cursor: pointer;
}

.section-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.section-icon {
  width: 40rpx;
  height: 40rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 评价图标 */
.icon-review::before {
  content: '';
  position: absolute;
  left: 6rpx;
  bottom: 6rpx;
  width: 10rpx;
  height: 18rpx;
  background: #ff6b35;
  border-radius: 2rpx;
}

.icon-review::after {
  content: '';
  position: absolute;
  right: 6rpx;
  bottom: 6rpx;
  width: 10rpx;
  height: 26rpx;
  background: #ff6b35;
  border-radius: 2rpx;
}

/* 关于图标 */
.icon-about {
  border: 3rpx solid #ff6b35;
  border-radius: 50%;
}

.icon-about::before {
  content: '';
  position: absolute;
  top: 8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 6rpx;
  height: 6rpx;
  background: #ff6b35;
  border-radius: 50%;
}

.icon-about::after {
  content: '';
  position: absolute;
  bottom: 6rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 4rpx;
  height: 12rpx;
  background: #ff6b35;
}

/* 帮助图标 */
.icon-help {
  border: 3rpx solid #ff6b35;
  border-radius: 50%;
}

.icon-help::before {
  content: '?';
  font-size: 24rpx;
  color: #ff6b35;
  font-weight: bold;
}

/* 联系图标 */
.icon-contact {
  border: 3rpx solid #ff6b35;
  border-radius: 50%;
}

.icon-contact::before {
  content: '';
  position: absolute;
  top: 8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 10rpx;
  height: 10rpx;
  border: 3rpx solid #ff6b35;
  border-radius: 50%;
  background: transparent;
}

.icon-contact::after {
  content: '';
  position: absolute;
  bottom: 6rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 20rpx;
  height: 10rpx;
  border: 3rpx solid #ff6b35;
  border-top: none;
  border-radius: 0 0 10rpx 10rpx;
}

.section-title {
  font-family: "Space Grotesk", "PingFang SC", sans-serif;
  font-size: 32rpx;
  font-weight: 700;
  color: #e5e2e1;
  letter-spacing: -0.3px;
}

.expand-icon {
  font-size: 28rpx;
  color: rgba(225, 191, 181, 0.5);
  padding: 8rpx;
}

/* ============================================
   加载状态
   ============================================ */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 4rpx solid #2a2a2a;
  border-top-color: #ff6b35;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 32rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: rgba(229, 226, 225, 0.6);
}

/* ============================================
   空状态
   ============================================ */
.empty-state-small {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
}

.empty-icon-small {
  font-size: 64rpx;
  margin-bottom: 16rpx;
  opacity: 0.8;
}

.empty-text {
  font-family: "Space Grotesk", "PingFang SC", sans-serif;
  font-size: 30rpx;
  color: #e5e2e1;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: rgba(225, 191, 181, 0.5);
}

/* ============================================
   紧凑评价列表 - 无分割线设计
   ============================================ */
.review-list-compact {
  padding: 0 32rpx;
}

.review-card-compact {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: flex-start;
  padding: 28rpx 0;
  /* 使用间距代替分割线 */
}

.review-card-compact:not(:last-child) {
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.compact-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.compact-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.compact-car {
  font-family: "Space Grotesk", "PingFang SC", sans-serif;
  font-size: 30rpx;
  color: #e5e2e1;
  font-weight: 600;
  letter-spacing: -0.3px;
}

.compact-score {
  font-size: 26rpx;
  color: rgba(225, 191, 181, 0.6);
}

.compact-status-desc {
  display: block;
  font-size: 22rpx;
  line-height: 1.5;
  color: rgba(225, 191, 181, 0.58);
}

.review-status-chip {
  padding: 6rpx 14rpx;
  border-radius: 9999rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.review-status-chip.approved {
  background: rgba(255, 155, 155, 0.1);
  color: #ff9b9b;
}

.review-status-chip.pending {
  background: rgba(255, 183, 77, 0.18);
  color: #ffd27d;
}

.review-status-chip.rejected {
  background: rgba(255, 82, 82, 0.16);
  color: #ff9b9b;
}

.compact-actions {
  display: flex;
  flex-direction: row;
  gap: 24rpx;
  align-items: center;
  padding-top: 2rpx;
}

.compact-btn {
  font-size: 26rpx;
  color: rgba(225, 191, 181, 0.72);
  padding: 8rpx 16rpx;
  font-weight: 500;
}

.compact-btn.disabled {
  opacity: 0.55;
}

.compact-btn.delete {
  color: rgba(225, 191, 181, 0.72);
}

/* ============================================
   加载更多
   ============================================ */
.load-more-small {
  text-align: center;
  padding: 32rpx;
  color: rgba(229, 226, 225, 0.4);
  font-size: 26rpx;
}

.load-more-small.no-more {
  color: rgba(229, 226, 225, 0.3);
}

/* ============================================
   查看全部按钮
   ============================================ */
.view-all-btn {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 28rpx;
  margin: 16rpx 32rpx 32rpx;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 16rpx;
  border: 1rpx solid rgba(225, 191, 181, 0.1);
}

.view-all-btn text:first-child {
  font-family: "Space Grotesk", "PingFang SC", sans-serif;
  font-size: 28rpx;
  color: rgba(225, 191, 181, 0.72);
  font-weight: 600;
}

.view-all-btn .arrow {
  font-size: 36rpx;
  color: rgba(225, 191, 181, 0.72);
  margin-left: 12rpx;
  line-height: 1;
}

.about-us-content {
  padding: 0 32rpx 32rpx;
}

.about-us-group {
  padding: 28rpx 0;
}

.about-us-group:not(:last-child) {
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.about-us-group-title {
  font-family: "Space Grotesk", "PingFang SC", sans-serif;
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #EDE8E6;
  margin-bottom: 20rpx;
}

/* ============================================
   关于内容
   ============================================ */
.about-content {
  padding: 0 32rpx 32rpx;
}

.about-content.merged,
.help-content.merged,
.contact-content.merged,
.account-content.merged {
  padding: 0;
}

.about-text {
  font-size: 28rpx;
  color: rgba(229, 226, 225, 0.8);
  line-height: 1.6;
  margin-bottom: 24rpx;
  display: block;
}

.about-features {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.feature-item {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 12rpx;
}

.feature-dot {
  font-size: 28rpx;
  color: #ff6b35;
  line-height: 1.4;
}

.feature-text {
  font-size: 26rpx;
  color: rgba(225, 191, 181, 0.7);
  line-height: 1.4;
  flex: 1;
}

/* ============================================
   账号管理 - 登录/退出
   ============================================ */
.account-content {
  padding: 32rpx;
  position: relative;
  z-index: 11;
}

.account-info {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.account-desc {
  font-size: 26rpx;
  color: rgba(225, 191, 181, 0.6);
  line-height: 1.5;
}

.user-info-row {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 107, 53, 0.3);
}

.user-meta {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-family: "Space Grotesk", "PingFang SC", sans-serif;
  font-size: 32rpx;
  font-weight: 600;
  color: #e5e2e1;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #ff6b35 0%, #ff8c42 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 16rpx;
}

.login-btn::after {
  border: none;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.04);
  color: rgba(225, 191, 181, 0.72);
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 16rpx;
  border: 1rpx solid rgba(225, 191, 181, 0.1);
}

.logout-btn::after {
  border: none;
}

/* 用户图标 */
.icon-user {
  border: 2rpx solid #ff6b35;
  border-radius: 50%;
  position: relative;
}

.icon-user::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -60%);
  width: 8rpx;
  height: 8rpx;
  background: #ff6b35;
  border-radius: 50%;
}

.icon-user::after {
  content: '';
  position: absolute;
  bottom: 20%;
  left: 50%;
  transform: translateX(-50%);
  width: 16rpx;
  height: 8rpx;
  border: 2rpx solid #ff6b35;
  border-top: none;
  border-radius: 0 0 8rpx 8rpx;
}

/* ============================================
   帮助内容
   ============================================ */
.help-content {
  padding: 0 32rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.help-item {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
}

.help-step {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff6b35 0%, #ff8c42 100%);
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 26rpx;
  color: #fff;
  font-weight: 700;
  flex-shrink: 0;
}

.help-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.help-title {
  font-size: 28rpx;
  color: #e5e2e1;
  font-weight: 600;
}

.help-desc {
  font-size: 24rpx;
  color: rgba(225, 191, 181, 0.6);
  line-height: 1.5;
}

/* ============================================
   联系内容
   ============================================ */
.contact-content {
  padding: 0 32rpx 32rpx;
}

.contact-desc {
  font-size: 26rpx;
  color: rgba(225, 191, 181, 0.6);
  margin-bottom: 24rpx;
  display: block;
}

.contact-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
}

.contact-label {
  font-size: 28rpx;
  color: rgba(225, 191, 181, 0.6);
  margin-right: 32rpx;
}

.contact-value {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.contact-value text:first-child {
  font-size: 32rpx;
  color: #e5e2e1;
  font-weight: 600;
  letter-spacing: 1px;
}

.contact-text {
  font-family: "Space Grotesk", "PingFang SC", sans-serif;
  font-size: 32rpx;
  color: #e5e2e1;
  font-weight: 600;
  letter-spacing: 1px;
}

/* ============================================
   底部留白
   ============================================ */
.bottom-space {
  height: calc(140rpx + env(safe-area-inset-bottom));
  min-height: 180rpx;
}

/* ============================================
   完善资料弹窗
   ============================================ */
.profile-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.profile-modal.show {
  opacity: 1;
  pointer-events: auto;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  backdrop-filter: blur(8px);
}

.modal-content {
  position: relative;
  width: 560rpx;
  background: #1c1b1b;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.modal-title {
  font-family: "Space Grotesk", "PingFang SC", sans-serif;
  font-size: 36rpx;
  font-weight: 700;
  color: #e5e2e1;
  margin-bottom: 12rpx;
}

.modal-desc {
  font-size: 26rpx;
  color: rgba(225, 191, 181, 0.6);
  margin-bottom: 40rpx;
}

.avatar-section {
  margin-bottom: 32rpx;
}

.avatar-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: transparent;
  padding: 0;
  margin: 0;
  line-height: normal;
}

.avatar-wrapper::after {
  border: none;
}

.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 107, 53, 0.3);
  margin-bottom: 16rpx;
  background: #2a2a2a;
}

.avatar-hint {
  font-size: 24rpx;
  color: #ff6b35;
}

.nickname-section {
  width: 100%;
  margin-bottom: 40rpx;
}

.input-label {
  display: block;
  font-size: 26rpx;
  color: rgba(225, 191, 181, 0.8);
  margin-bottom: 16rpx;
}

.nickname-input {
  width: 100%;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #e5e2e1;
  box-sizing: border-box;
}

.modal-actions {
  display: flex;
  flex-direction: row;
  gap: 24rpx;
  width: 100%;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
}

.modal-btn::after {
  border: none;
}

.modal-btn.cancel {
  background: rgba(255, 255, 255, 0.06);
  color: rgba(225, 191, 181, 0.72);
}

.modal-btn.confirm {
  background: rgba(255, 255, 255, 0.06);
  color: rgba(225, 191, 181, 0.72);
  border: 1rpx solid rgba(225, 191, 181, 0.12);
}
