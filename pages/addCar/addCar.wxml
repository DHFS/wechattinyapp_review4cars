<view class="page">
  <view class="header">
    <text class="header-title">添加新车型</text>
    <text class="header-subtitle">品牌和车型支持本地联想，提交前会再做一次智能纠错</text>
  </view>

  <view class="form-section">
    <view class="form-item">
      <text class="form-label">品牌厂家 <text class="required">*</text></text>
      <input
        class="form-input"
        placeholder="如：特斯拉、比亚迪、理想"
        value="{{formData.brand}}"
        data-field="brand"
        bindinput="onInputChange"
        bindfocus="onBrandFocus"
        bindblur="onInputBlur"
        hold-keyboard="{{true}}"
        always-embed="{{true}}"
      />

      <view class="inline-suggestion-list" wx:if="{{showBrandSuggestions}}">
        <view
          wx:for="{{brandSuggestions}}"
          wx:key="name"
          class="suggestion-item"
          data-brand="{{item.name}}"
          bindtap="selectBrandSuggestion"
        >
          <text class="suggestion-title">{{item.name}}</text>
          <text class="suggestion-subtitle">{{item.subtitle}}</text>
        </view>
      </view>
    </view>

    <view class="form-item">
      <text class="form-label">车型名称 <text class="required">*</text></text>
      <input
        class="form-input"
        placeholder="如：Model 3、汉EV、L9"
        value="{{formData.model}}"
        data-field="model"
        bindinput="onInputChange"
        bindfocus="onModelFocus"
        bindblur="onInputBlur"
        hold-keyboard="{{true}}"
        always-embed="{{true}}"
      />
    </view>

    <view class="form-item">
      <text class="form-label">年款 <text class="required">*</text></text>
      <input
        class="form-input"
        placeholder="如：2024款"
        value="{{formData.year}}"
        data-field="year"
        bindinput="onInputChange"
        always-embed="{{true}}"
      />
    </view>

    <view class="form-item">
      <text class="form-label">动力形式 <text class="required">*</text></text>
      <view class="power-type-list">
        <view
          wx:for="{{powerTypes}}"
          wx:key="value"
          class="power-type-item {{formData.powerType === item.value ? 'active' : ''}}"
          data-value="{{item.value}}"
          bindtap="onPowerTypeSelect"
        >
          <view class="power-color" style="background: {{item.color}};"></view>
          <text class="power-name">{{item.name}}</text>
        </view>
      </view>
    </view>

    <view class="form-item">
      <text class="form-label">售价区间 <text class="required">*</text></text>
      <input
        class="form-input"
        placeholder="如：23.19-33.19万"
        value="{{formData.price}}"
        data-field="price"
        bindinput="onInputChange"
        always-embed="{{true}}"
      />
    </view>
  </view>

  <button class="submit-btn" bindtap="submitCar" loading="{{submitting}}">
    {{submitting ? '提交中...' : '提交新车型'}}
  </button>

  <view class="tips-section">
    <text class="tips-title">使用建议：</text>
    <text class="tips-item">1. 先输入品牌，再从联想结果里选择车型，会更准确</text>
    <text class="tips-item">2. 如果输成了别名、英文或错别字，提交前会再尝试纠错</text>
    <text class="tips-item">3. 这版词典是本地优先，后面再逐步接入混元做更强纠错</text>
  </view>

  <view
    class="suggestion-mask"
    wx:if="{{showSuggestionPanel}}"
    catchtouchmove="noop"
    bindtap="onSuggestionMaskTap"
  ></view>

  <view
    class="floating-suggestion-panel"
    wx:if="{{showSuggestionPanel && suggestionField === 'model'}}"
    style="bottom: {{panelBottomOffset}}px;"
  >
    <view class="floating-suggestion-panel-bg"></view>

    <view class="floating-suggestion-header">
      <text class="floating-suggestion-title">推荐车型</text>
      <text class="floating-suggestion-close" bindtap="onSuggestionMaskTap">收起</text>
    </view>

    <scroll-view class="floating-suggestion-scroll" scroll-y enhanced show-scrollbar="false">
      <view
        wx:for="{{suggestionItems}}"
        wx:key="id"
        class="suggestion-item"
        data-brand="{{item.brand}}"
        data-model="{{item.model}}"
        data-powertype="{{item.powerType}}"
        data-pricerange="{{item.priceRange}}"
        bindtap="selectModelSuggestion"
      >
        <view class="suggestion-top">
          <text class="suggestion-title">{{item.brand}} {{item.model}}</text>
          <text
            class="suggestion-tag"
            wx:if="{{item.powerType}}"
            style="color: {{item.powerTypeColor}}; background: {{item.powerTypeBackground}};"
          >{{item.powerType}}</text>
        </view>
        <text class="suggestion-subtitle">{{item.subtitle}}</text>
      </view>
    </scroll-view>
  </view>
</view>
