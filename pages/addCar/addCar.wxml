<view class="page">
  <!-- 页面标题 -->
  <view class="header">
    <text class="header-title">添加新车型</text>
    <text class="header-subtitle">填写车辆信息，让更多车友参与评价</text>
  </view>

  <!-- 表单区域 -->
  <view class="form-section">
    
    <!-- 品牌厂家 -->
    <view class="form-item">
      <text class="form-label">品牌厂家 <text class="required">*</text></text>
      <input 
        class="form-input" 
        placeholder="如：特斯拉、比亚迪、理想" 
        value="{{formData.brand}}"
        data-field="brand"
        bindinput="onInputChange"
      />
    </view>

    <!-- 车型名称 -->
    <view class="form-item">
      <text class="form-label">车型名称 <text class="required">*</text></text>
      <input 
        class="form-input" 
        placeholder="如：Model 3、汉EV、L9" 
        value="{{formData.model}}"
        data-field="model"
        bindinput="onInputChange"
      />
    </view>

    <!-- 年款 -->
    <view class="form-item">
      <text class="form-label">年款 <text class="required">*</text></text>
      <input 
        class="form-input" 
        placeholder="如：2024款" 
        value="{{formData.year}}"
        data-field="year"
        bindinput="onInputChange"
      />
    </view>

    <!-- 动力形式 -->
    <view class="form-item">
      <text class="form-label">动力形式 <text class="required">*</text></text>
      <view class="power-type-list">
        <view 
          wx:for="{{powerTypes}}" 
          wx:key="value"
          class="power-type-item {{formData.powerType === item.value ? 'active' : ''}}"
          data-value="{{item.value}}"
          bindtap="onPowerTypeSelect"
        >
          <view class="power-color" style="background: {{item.color}};"></view>
          <text class="power-name">{{item.name}}</text>
        </view>
      </view>
    </view>

    <!-- 售价区间 -->
    <view class="form-item">
      <text class="form-label">售价区间 <text class="required">*</text></text>
      <input 
        class="form-input" 
        placeholder="如：23.19-33.19万" 
        value="{{formData.price}}"
        data-field="price"
        bindinput="onInputChange"
      />
    </view>

    <!-- TODO: 车辆图片上传功能（预留接口，未来升级） -->
    <!-- 
    <view class="form-item">
      <text class="form-label">车辆图片</text>
      <view class="image-upload" bindtap="chooseImage">
        <image wx:if="{{formData.imageUrl}}" class="uploaded-image" src="{{formData.imageUrl}}" mode="aspectFill"/>
        <view wx:else class="upload-placeholder">
          <text class="upload-icon">+</text>
          <text class="upload-text">点击上传车辆图片</text>
        </view>
      </view>
    </view>
    -->

  </view>

  <!-- 提交按钮 -->
  <button class="submit-btn" bindtap="submitCar" loading="{{submitting}}">
    {{submitting ? '提交中...' : '提交新车型'}}
  </button>

  <!-- 提示信息 -->
  <view class="tips-section">
    <text class="tips-title">温馨提示：</text>
    <text class="tips-item">1. 请确保填写的车型信息准确无误</text>
    <text class="tips-item">2. 车型添加后将立即上架展示</text>
    <text class="tips-item">3. 邀请车友们来为新车打分评价吧</text>
  </view>
</view>
