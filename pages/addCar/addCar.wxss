/* 提交按钮 */
.submit-btn {
  width: 100%;
  height: 52px;
  background: linear-gradient(135deg, #FF6B35, #FF8C42);
  color: #FFFFFF;
  font-size: 16px;
  font-weight: 600;
  border-radius: 26px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-bottom: 20px;
}

.submit-btn::after {
  border: none;
}

.submit-btn[disabled] {
  opacity: 0.6;
}

/* 提示信息 */
.tips-section {
  background: rgba(255, 107, 53, 0.05);
  border-radius: 12px;
  padding: 16px;
  border: 1px solid rgba(255, 107, 53, 0.2);
}

.tips-title {
  display: block;
  font-size: 14px;
  font-weight: 600;
  color: #FF6B35;
  margin-bottom: 10px;
}

.tips-item {
  display: block;
  font-size: 12px;
  color: #888888;
  line-height: 1.8;
}
