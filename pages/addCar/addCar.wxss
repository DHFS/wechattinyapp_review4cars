page {
  background: #121212;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
}

.page {
  padding: 16px;
  padding-bottom: 40px;
}

.header {
  margin-bottom: 16px;
}

.header-title {
  font-size: 24px;
  font-weight: 700;
  color: #FFFFFF;
  display: block;
  margin-bottom: 6px;
}

.header-subtitle {
  font-size: 13px;
  color: #777777;
}

.audit-banner {
  margin-bottom: 16px;
  padding: 14px 16px;
  border-radius: 14px;
  background: rgba(255, 107, 53, 0.08);
  border: 1px solid rgba(255, 107, 53, 0.16);
}

.audit-banner-title {
  display: block;
  font-size: 14px;
  font-weight: 700;
  color: #FFB38E;
  margin-bottom: 6px;
}

.audit-banner-desc {
  display: block;
  font-size: 12px;
  line-height: 1.6;
  color: #B8B0AC;
}

.form-section {
  background: #1A1A1A;
  border-radius: 16px;
  padding: 20px;
  margin-bottom: 20px;
}

.form-item {
  margin-bottom: 20px;
  position: relative;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 14px;
  color: #AAAAAA;
  margin-bottom: 10px;
}

.required {
  color: #FF6B35;
}

.form-input {
  width: 100%;
  height: 48px;
  background: #252525;
  border-radius: 10px;
  padding: 0 16px;
  font-size: 15px;
  color: #FFFFFF;
  box-sizing: border-box;
}

.form-input::placeholder {
  color: #555555;
}

.suggestion-list,
.inline-suggestion-list {
  margin-top: 8px;
  background: #202020;
  border: 1px solid #2F2F2F;
  border-radius: 12px;
  overflow: hidden;
  position: relative;
  z-index: 8;
}

.inline-suggestion-list {
  box-shadow: 0 10px 24px rgba(0, 0, 0, 0.2);
}

.suggestion-item {
  padding: 12px 14px;
  border-bottom: 1px solid #2A2A2A;
}

.suggestion-item:last-child {
  border-bottom: none;
}

.suggestion-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
}

.suggestion-title {
  color: #FFFFFF;
  font-size: 14px;
  font-weight: 600;
}

.suggestion-subtitle {
  display: block;
  color: #8D8D8D;
  font-size: 12px;
  margin-top: 4px;
}

.suggestion-tag {
  flex-shrink: 0;
  font-size: 11px;
  color: #FFB38E;
  background: rgba(255, 107, 53, 0.14);
  border-radius: 10px;
  padding: 4px 8px;
}

.suggestion-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.18);
  z-index: 20;
}

.floating-suggestion-panel {
  position: fixed;
  left: 16px;
  right: 16px;
  background: #1C1C1C;
  border: 1px solid #313131;
  border-radius: 18px;
  box-shadow: 0 12px 36px rgba(0, 0, 0, 0.42);
  overflow: hidden;
  z-index: 21;
}

.floating-suggestion-panel-bg {
  position: absolute;
  inset: 0;
  background: #1C1C1C;
  z-index: 0;
}

.floating-suggestion-header {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 16px 12px;
  border-bottom: 1px solid #2A2A2A;
  background: rgba(255, 255, 255, 0.02);
}

.floating-suggestion-title {
  font-size: 13px;
  font-weight: 600;
  color: #F2F2F2;
}

.floating-suggestion-close {
  font-size: 12px;
  color: #9A9A9A;
}

.floating-suggestion-scroll {
  position: relative;
  z-index: 1;
  max-height: 320px;
  background: #1C1C1C;
}

.floating-suggestion-scroll .suggestion-item {
  background: #1C1C1C;
}

.power-type-list {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 10px;
}

.power-type-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 6px;
  background: #252525;
  border-radius: 8px;
  padding: 10px 14px;
  border: 2px solid transparent;
  transition: all 0.2s;
}

.power-type-item.active {
  border-color: #FF6B35;
  background: rgba(255, 107, 53, 0.1);
}

.power-color {
  width: 8px;
  height: 8px;
  border-radius: 50%;
}

.power-name {
  font-size: 13px;
  color: #CCCCCC;
}

.power-type-item.active .power-name {
  color: #FFFFFF;
}

.submit-btn {
  width: 100%;
  height: 52px;
  background: linear-gradient(135deg, #FF6B35, #FF8C42);
  color: #FFFFFF;
  font-size: 16px;
  font-weight: 600;
  border-radius: 26px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-bottom: 20px;
}

.submit-btn::after {
  border: none;
}

.submit-btn[disabled] {
  opacity: 0.6;
}

.tips-section {
  background: rgba(255, 107, 53, 0.05);
  border-radius: 12px;
  padding: 16px;
  border: 1px solid rgba(255, 107, 53, 0.2);
}

.tips-title {
  display: block;
  font-size: 14px;
  font-weight: 600;
  color: #FF6B35;
  margin-bottom: 10px;
}

.tips-item {
  display: block;
  font-size: 12px;
  color: #888888;
  line-height: 1.8;
}

/* ============================================
   Image Upload 图片上传
   ============================================ */
.image-upload-wrap {
  width: 100%;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 180px;
  background: #1c1b1b;
  border: 2px dashed #2a2a2a;
  border-radius: 16px;
  transition: all 0.2s;
}

.upload-placeholder:active {
  background: #252525;
  border-color: #ff6b35;
}

.upload-icon {
  font-size: 40px;
  color: #ff6b35;
  font-weight: 300;
  margin-bottom: 8px;
}

.upload-text {
  font-size: 15px;
  color: #e5e2e1;
  font-weight: 500;
  margin-bottom: 6px;
}

.upload-hint {
  font-size: 12px;
  color: #666666;
}

.upload-preview {
  position: relative;
  width: 100%;
  border-radius: 16px;
  overflow: hidden;
  background: #1c1b1b;
}

.preview-image {
  width: 100%;
  height: 200px;
  display: block;
}

.preview-actions {
  display: flex;
  gap: 12px;
  padding: 16px;
  background: #1c1b1b;
}

.preview-btn {
  flex: 1;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20px;
  font-size: 14px;
  font-weight: 500;
}

.preview-btn.change {
  background: #2a2a2a;
  color: #e5e2e1;
}

.preview-btn.delete {
  background: rgba(255, 107, 53, 0.15);
  color: #ff6b35;
}
