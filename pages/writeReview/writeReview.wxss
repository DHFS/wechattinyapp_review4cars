/* pages/writeReview/writeReview.wxss */
page {
  min-height: 100vh;
  background: #121212;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
}

.container {
  min-height: 100vh;
  background: #121212;
}

/* ========== 通用头部 ========== */
.header {
  position: sticky;
  top: 0;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  padding-top: calc(12px + env(safe-area-inset-top));
  background-color: rgba(18, 18, 18, 0.96);
  border-bottom: 0.5px solid #333;
}

.cancel-btn, .back-btn {
  display: flex;
  align-items: center;
  padding: 8px 0;
  min-width: 60px;
}

.cancel-icon {
  font-size: 28px;
  color: #888;
  line-height: 1;
}

.back-icon {
  font-size: 18px;
  color: #888;
  margin-right: 4px;
}

.back-text {
  font-size: 15px;
  color: #888;
}

.title {
  font-size: 17px;
  font-weight: 600;
  color: #FFFFFF;
  text-align: center;
  flex: 1;
  padding: 0 16px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.next-btn, .submit-btn {
  min-width: 60px;
  text-align: right;
}

.next-btn text {
  font-size: 15px;
  color: #FF6B35;
  font-weight: 500;
}

.submit-btn text {
  font-size: 15px;
  color: #FF6B35;
  font-weight: 600;
}

.submit-btn.disabled text {
  color: #666;
}

/* ========== 评分步骤 ========== */
.step {
  min-height: 100vh;
  padding-bottom: calc(100px + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.step-content {
  padding: 16px 0 0;
}

.rating-content {
  padding-bottom: 12px;
}

.writing-content {
  padding-bottom: 12px;
}

.total-score-section {
  padding: 24px 20px 20px;
  background: #1A1A1A;
  border-radius: 0;
  text-align: center;
  margin-bottom: 16px;
}

.score-display {
  margin-bottom: 8px;
}

.score-value {
  font-size: 56px;
  font-weight: 800;
  color: #FFD700;
  line-height: 1;
}

.score-label {
  display: block;
  font-size: 14px;
  color: #888;
  margin-top: 4px;
}

.score-hint {
  font-size: 13px;
  color: #666;
}

/* 评分列表 */
.rating-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.rating-item {
  padding: 20px 16px;
  background: #1A1A1A;
  border-radius: 0;
}

.rating-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 4px;
}

.rating-name {
  font-size: 16px;
  font-weight: 600;
  color: #FFFFFF;
}

.rating-value {
  font-size: 18px;
  font-weight: 600;
  color: #FF6B35;
}

.rating-value.unrated {
  font-size: 14px;
  color: #666;
  font-weight: 400;
}

.rating-desc {
  font-size: 13px;
  color: #666;
  line-height: 1.5;
  margin-bottom: 12px;
}

/* 滑块样式 */
.slider-surface {
  background: #252525;
  border-radius: 12px;
  padding: 14px 12px 12px;
}

.slider-container {
  display: flex;
  align-items: center;
  gap: 8px;
}

.slider-label {
  font-size: 12px;
  color: #666;
  width: 28px;
  text-align: center;
}

.rating-slider {
  flex: 1;
  margin: 0;
  padding: 10px 0;
}

.quick-score-row {
  display: flex;
  justify-content: space-between;
  gap: 0;
  flex-wrap: nowrap;
  margin-top: 12px;
}

.quick-score-chip {
  width: 18%;
  height: 34px;
  border-radius: 10px;
  background: #252525;
  border: 1px solid #363636;
  display: flex;
  align-items: center;
  justify-content: center;
}

.quick-score-text {
  font-size: 12px;
  color: #CFCFCF;
}

.rating-tip {
  padding: 8px 4px 4px;
  text-align: center;
}

.tip-text {
  font-size: 12px;
  color: #555;
  line-height: 1.6;
}

.rating-bottom-safe {
  height: calc(12px + env(safe-area-inset-bottom));
}

.rating-footer {
  position: sticky;
  bottom: 0;
  z-index: 9;
  padding: 12px 16px;
  padding-bottom: calc(12px + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(18, 18, 18, 0) 0%, rgba(18, 18, 18, 0.92) 40%, #121212 100%);
}

.bottom-action-btn {
  width: 100%;
  height: 52px;
  border-radius: 26px;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C42 100%);
  color: #FFFFFF;
  font-size: 16px;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.bottom-action-btn::after {
  border: none;
}

/* ========== 写作步骤 ========== */
.writing-step {
  background: transparent;
}

/* 评分摘要 */
.score-summary {
  padding: 20px 16px;
  background: #1A1A1A;
  border-radius: 0;
  margin-bottom: 16px;
}

.summary-title {
  font-size: 15px;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 10px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.summary-scores {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 40px;
}

.summary-label {
  font-size: 11px;
  color: #888;
  margin-bottom: 2px;
}

.summary-value {
  font-size: 16px;
  font-weight: 600;
  color: #FFF;
}

.summary-value.highlight {
  color: #FF6B35;
}

/* 写作区域 */
.writing-area {
  background: #1A1A1A;
  border-radius: 0;
  overflow: hidden;
}

.comment-editor {
  width: 100%;
  min-height: 56vh;
  padding: 16px;
  font-size: 16px;
  line-height: 1.9;
  color: #FFFFFF;
  background-color: #1A1A1A;
  box-sizing: border-box;
}

.placeholder-text {
  font-size: 16px;
  color: #555;
  line-height: 1.9;
}

/* 底部工具栏 */
.toolbar {
  margin-top: 12px;
  padding: 12px 16px;
  padding-bottom: calc(12px + env(safe-area-inset-bottom));
  background-color: rgba(18, 18, 18, 0.96);
  border-top: 0.5px solid #2A2A2A;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.char-count {
  font-size: 13px;
  color: #666;
}

.toolbar-actions {
  display: flex;
  gap: 16px;
}

.action-btn {
  padding: 6px 12px;
  border-radius: 6px;
  background-color: #2A2A2A;
}

.action-btn text {
  font-size: 13px;
  color: #888;
}

/* ========== 资料设置弹窗 ========== */
.profile-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.profile-modal.show {
  opacity: 1;
  pointer-events: auto;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.7);
}

.modal-content {
  position: relative;
  width: 80%;
  max-width: 320px;
  background-color: #1A1A1A;
  border-radius: 16px;
  padding: 24px;
  z-index: 1001;
}

.modal-title {
  font-size: 18px;
  font-weight: 600;
  color: #FFFFFF;
  text-align: center;
  margin-bottom: 8px;
}

.modal-desc {
  font-size: 14px;
  color: #888;
  text-align: center;
  display: block;
  margin-bottom: 20px;
}

.avatar-section {
  display: flex;
  justify-content: center;
  margin-bottom: 20px;
}

.avatar-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: none;
  border: none;
  padding: 0;
}

.avatar-wrapper::after {
  border: none;
}

.avatar-img {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  margin-bottom: 8px;
  background-color: #333;
}

.avatar-hint {
  font-size: 12px;
  color: #FF6B35;
}

.nickname-section {
  margin-bottom: 20px;
}

.input-label {
  font-size: 14px;
  color: #888;
  margin-bottom: 8px;
  display: block;
}

.nickname-input {
  width: 100%;
  height: 44px;
  background-color: #252525;
  border-radius: 8px;
  padding: 0 12px;
  font-size: 15px;
  color: #FFFFFF;
  box-sizing: border-box;
}

.modal-actions {
  display: flex;
  gap: 12px;
}

.modal-btn {
  flex: 1;
  height: 44px;
  border-radius: 8px;
  font-size: 15px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  background: none;
}

.modal-btn::after {
  border: none;
}

.modal-btn.cancel {
  background-color: #333;
  color: #888;
}

.modal-btn.confirm {
  background-color: #FF6B35;
  color: #FFFFFF;
}
