page {
  background: #131313;
  color: #e5e2e1;
  font-family: "Inter", "PingFang SC", -apple-system, BlinkMacSystemFont, sans-serif;
}

.page {
  min-height: 100vh;
  background: #131313;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.page-body {
  padding: 0 32rpx 0;
}

.archive-header {
  display: flex;
  align-items: flex-end;
}

.archive-copy {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.archive-kicker {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  color: #ffb59d;
}

.archive-title {
  font-family: "Space Grotesk", "PingFang SC", sans-serif;
  font-size: 64rpx;
  font-weight: 700;
  line-height: 1;
  text-transform: uppercase;
  color: #e5e2e1;
}

.archive-line {
  width: 96rpx;
  height: 4rpx;
  background: #ff6b35;
  margin: 20rpx 0 28rpx;
  border-radius: 999rpx;
}

.archive-summary {
  display: flex;
  gap: 20rpx;
  margin-bottom: 36rpx;
}

.summary-card {
  flex: 1;
  background: #1c1b1b;
  border-radius: 24rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.summary-label {
  display: block;
  font-size: 22rpx;
  color: rgba(225, 191, 181, 0.6);
  margin-bottom: 12rpx;
}

.summary-value {
  font-family: "Space Grotesk", "PingFang SC", sans-serif;
  font-size: 52rpx;
  line-height: 1;
  font-weight: 700;
  color: #ff9b9b;
}

.loading-state,
.empty-state {
  min-height: 50vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.loading-spinner {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.12);
  border-top-color: #ff6b35;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: rgba(225, 191, 181, 0.58);
}

.empty-code {
  font-family: "Space Grotesk", "PingFang SC", sans-serif;
  font-size: 96rpx;
  font-weight: 700;
  line-height: 1;
  color: rgba(225, 191, 181, 0.18);
}

.empty-title {
  font-family: "Space Grotesk", "PingFang SC", sans-serif;
  margin-top: 20rpx;
  font-size: 40rpx;
  font-weight: 700;
  text-transform: uppercase;
  color: #e5e2e1;
}

.empty-desc {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: rgba(225, 191, 181, 0.58);
}

.dossier-list {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.dossier-card {
  overflow: hidden;
  border-radius: 24rpx;
  background: #1c1b1b;
  box-shadow: 0 20rpx 48rpx rgba(0, 0, 0, 0.45);
  border: 1rpx solid rgba(255, 255, 255, 0.04);
}

.dossier-media {
  position: relative;
  width: 100%;
  height: 320rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #2b211d, #171717);
}

.dossier-image {
  width: 100%;
  height: 100%;
}

.dossier-image.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    radial-gradient(circle at top left, rgba(255, 107, 53, 0.18), transparent 45%),
    linear-gradient(135deg, #292120, #161616);
}

.dossier-overlay {
  position: absolute;
  top: 24rpx;
  left: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  align-items: flex-start;
}

.dossier-badge {
  padding: 10rpx 18rpx;
  border-radius: 14rpx;
  background: rgba(180, 180, 180, 0.14);
  color: rgba(229, 226, 225, 0.55);
  font-family: "Space Grotesk", "PingFang SC", sans-serif;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.dossier-content {
  padding: 28rpx;
}

.dossier-head {
  display: flex;
  gap: 20rpx;
  justify-content: space-between;
}

.dossier-title-wrap {
  flex: 1;
  min-width: 0;
}

.dossier-title {
  display: block;
  font-family: "Space Grotesk", "PingFang SC", sans-serif;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.1;
  color: #e5e2e1;
}

.dossier-meta {
  display: block;
  margin-top: 10rpx;
  font-size: 20rpx;
  line-height: 1.5;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  color: rgba(225, 191, 181, 0.68);
}

.dossier-score {
  flex-shrink: 0;
  min-width: 96rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.dossier-score-value {
  display: block;
  width: 100%;
  font-family: "Space Grotesk", "PingFang SC", sans-serif;
  font-size: 80rpx;
  line-height: 0.9;
  font-weight: 700;
  text-align: right;
  color: #ff9b9b;
}

.dossier-score-label {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 96rpx;
  margin-top: 8rpx;
  line-height: 1;
  color: rgba(225, 191, 181, 0.56);
}

.score-letter {
  font-size: 18rpx;
  font-weight: 700;
  text-transform: uppercase;
}

.dossier-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 22rpx;
}

.dossier-tag {
  padding: 8rpx 18rpx;
  border-radius: 14rpx;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
  white-space: nowrap;
}

.dossier-tag.power,
.dossier-tag.status,
.dossier-tag.neutral {
  font-size: 22rpx;
}

.dossier-tag.status.approved {
  background: rgba(34, 165, 104, 0.18);
  color: #7ed9aa;
}

.dossier-tag.status.pending {
  background: rgba(255, 183, 77, 0.18);
  color: #ffd27d;
}

.dossier-tag.inline-status.approved {
  background: rgba(255, 155, 155, 0.16);
  color: #ff9b9b;
}

.dossier-tag.inline-status.pending {
  background: rgba(255, 183, 77, 0.28);
  color: #ffcf6d;
}

.dossier-tag.inline-status.rejected {
  background: rgba(255, 82, 82, 0.2);
  color: #ff6b6b;
}

.dossier-tag.status.rejected {
  background: rgba(255, 82, 82, 0.16);
  color: #ff9b9b;
}

.dossier-tag.neutral {
  background: rgba(255, 255, 255, 0.06);
  color: rgba(229, 226, 225, 0.7);
}

.dossier-tag.inline-status.approved {
  background: rgba(255, 155, 155, 0.1);
  color: #ff9b9b;
}

.status-desc {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(225, 191, 181, 0.56);
}

.quote-box {
  margin-top: 24rpx;
  padding: 0 0 0 24rpx;
  border-left: 4rpx solid rgba(169, 138, 128, 0.3);
}

.quote-text {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
  font-size: 28rpx;
  line-height: 1.8;
  font-style: italic;
  color: rgba(229, 226, 225, 0.82);
}

.dimension-strip {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 24rpx;
}

.dimension-chip {
  min-width: 108rpx;
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  background: #2a2a2a;
  text-align: center;
}

.dimension-name {
  display: block;
  font-size: 20rpx;
  color: rgba(225, 191, 181, 0.56);
}

.dimension-score {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #e5e2e1;
}

.dossier-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(169, 138, 128, 0.12);
}

.action-group {
  display: flex;
  flex-wrap: wrap;
  gap: 28rpx;
}

.text-action {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 0;
  margin: 0;
  line-height: 1;
  background: transparent;
  border: 0;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  color: rgba(225, 191, 181, 0.72);
}

.share-button-inline {
  display: flex;
  align-items: center;
  gap: 12rpx;
  justify-content: flex-start;
  padding: 0;
  margin: 0;
  min-height: auto;
  line-height: 1;
  background: transparent;
  border: 0;
  outline: none;
  box-shadow: none;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  color: rgba(225, 191, 181, 0.72);
}

.share-button-inline::after {
  border: 0;
  width: 0;
  height: 0;
}

.action-hover {
  color: #ffb59d;
}

.action-danger-hover {
  color: #ffb59d;
}

.text-action.disabled {
  opacity: 0.55;
}

.text-action.danger {
  color: rgba(225, 191, 181, 0.72);
}

.action-symbol {
  font-size: 26rpx;
  line-height: 1;
}

.action-label {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  line-height: 1;
}

.share-icon {
  font-size: 26rpx;
}

.ghost-action {
  flex-shrink: 0;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(169, 138, 128, 0.2);
  background: #2a2a2a;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  color: #e5e2e1;
}

.ghost-action.disabled {
  opacity: 0.5;
}

.load-more {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 40rpx 0 48rpx;
}

.load-more-label {
  font-family: "Space Grotesk", "PingFang SC", sans-serif;
  font-size: 20rpx;
  letter-spacing: 6rpx;
  text-transform: uppercase;
  color: rgba(225, 191, 181, 0.72);
}

.load-more-icon {
  font-size: 42rpx;
  line-height: 1;
  color: #ff6b35;
}

.load-more.done .load-more-label {
  letter-spacing: 2rpx;
}
