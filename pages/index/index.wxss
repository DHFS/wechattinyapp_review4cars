/* 全局重置 */
page {
  background: #121212;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  -webkit-font-smoothing: antialiased;
}

.page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 0 16px 32px;
}

/* 头部 */
.header {
  padding: 48px 0 32px;
}

.header-title {
  font-size: 28px;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: -0.5px;
  margin-bottom: 6px;
}

.header-subtitle {
  font-size: 13px;
  color: #666666;
}

/* 列表 */
.list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

/* 卡片 - 极简无框，用留白分隔 */
.card {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  background: #1A1A1A;
  border-radius: 16px;
  padding: 20px 16px;
}

.card:active {
  opacity: 0.8;
}

/* 前三名特殊样式 */
.card.top-three {
  background: linear-gradient(to right, #1E1E1E, #252525);
  border: 1px solid #333333;
}

/* 第一名 - 霓虹红橙 */
.card.rank-0 {
  border-left: 4px solid #FF2D55;
}

/* 第二名 - 品牌橙 */
.card.rank-1 {
  border-left: 4px solid #FF6B35;
}

/* 第三名 - 金黄 */
.card.rank-2 {
  border-left: 4px solid #FFCC00;
}

/* 左侧：名次区 */
.rank-col {
  width: 48px;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
}

.rank-num {
  font-size: 30px;
  font-weight: 600;
  color: #AAAAAA;
}

/* 前三名特殊样式 - 仅作用于名次数字，避免影响整张卡片文本 */
.rank-num.rank-0 {
  font-size: 30px;
  font-weight: 800;
  color: #FF2D55;
  text-shadow: 0 0 6px rgba(255, 45, 85, 0.28), 0 0 14px rgba(255, 45, 85, 0.16);
}

.rank-num.rank-1 {
  font-size: 30px;
  font-weight: 700;
  color: #FF6B35;
  text-shadow: 0 0 5px rgba(255, 107, 53, 0.24), 0 0 12px rgba(255, 107, 53, 0.14);
}

.rank-num.rank-2 {
  font-size: 30px;
  font-weight: 700;
  color: #FFCC00;
  text-shadow: 0 0 4px rgba(255, 204, 0, 0.22), 0 0 10px rgba(255, 204, 0, 0.12);
}

/* 中间：信息区 */
.info-col {
  display: flex;
  flex-direction: column;
  flex: 1;
  margin: 0 12px;
  gap: 5px;
}

.car-name {
  font-size: 17px;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.2;
}

.tag-row {
  display: flex;
  flex-direction: row;
  gap: 8px;
}

.tag {
  display: inline-flex;
  font-size: 10px;
  font-weight: 500;
  padding: 3px 8px;
  border-radius: 4px;
  line-height: 1;
}

/* 动力类型标签颜色 */
.tag-zengcheng {
  background: #007eba;
  color: #FFFFFF;
}

.tag-chundi {
  background: #22a568;
  color: #FFFFFF;
}

.tag-ranyou {
  background: #ffa200;
  color: #FFFFFF;
}

.tag-chahun {
  background: #c172d4;
  color: #FFFFFF;
}

.car-meta {
  font-size: 12px;
  color: #555555;
  line-height: 1.2;
}

/* 右侧：评分区 */
.score-col {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: space-between;
  flex-shrink: 0;
  min-width: 85px;
}

.score {
  font-size: 24px;
  font-weight: 900;
  color: #FFFFFF;
  line-height: 1;
  letter-spacing: -0.5px;
}

/* 前三名分数霓虹光谱配色 */
.score-rank-0 {
  color: #FF2D55;
  text-shadow: 0 0 6px rgba(255, 45, 85, 0.28), 0 0 14px rgba(255, 45, 85, 0.16);
}

.score-rank-1 {
  color: #FF6B35;
  text-shadow: 0 0 5px rgba(255, 107, 53, 0.24), 0 0 12px rgba(255, 107, 53, 0.14);
}

.score-rank-2 {
  color: #FFCC00;
  text-shadow: 0 0 4px rgba(255, 204, 0, 0.22), 0 0 10px rgba(255, 204, 0, 0.12);
}

.count {
  font-size: 12px;
  color: #555555;
  line-height: 1.2;
}

/* 点评用户头像堆叠 - 从右向左，新的在上层 */
.reviewer-avatars {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-top: 4px;
  height: 22px;
}

.avatar-stack {
  display: flex;
  flex-direction: row-reverse;
  align-items: center;
  margin-right: 4px;
}

.avatar-img {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  border: 1px solid #1A1A1A;
  background-color: #333333;
  flex-shrink: 0;
  margin-right: -8px;
  position: relative;
}

.avatar-img:first-child {
  margin-right: 0;
}

.review-count-text {
  font-size: 12px;
  color: #666666;
  margin-left: 10px;
  white-space: nowrap;
  flex-shrink: 0;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 24px 16px 100px;
  color: #666666;
  font-size: 13px;
}

.load-more.no-more {
  color: #666666;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100px 20px;
}

.loading-spinner {
  width: 40px;
  height: 40px;
  border: 3px solid #333333;
  border-top-color: #FF6B35;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 16px;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 14px;
  color: #666666;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80px 20px;
}

.empty-icon {
  font-size: 64px;
  margin-bottom: 20px;
}

.empty-title {
  font-size: 18px;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 8px;
}

.empty-desc {
  font-size: 13px;
  color: #666666;
  margin-bottom: 24px;
}

.empty-btn {
  background: linear-gradient(135deg, #FF6B35, #FF8C42);
  color: #FFFFFF;
  font-size: 14px;
  font-weight: 600;
  padding: 12px 32px;
  border-radius: 24px;
}

/* 安全区适配 */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 添加车型按钮已移至底部导航栏中间 */
