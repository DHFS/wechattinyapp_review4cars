<view class="tab-bar">
  <view class="tab-bar-item {{selected === index ? 'active' : ''}}" 
        wx:for="{{list}}" 
        wx:key="index"
        data-path="{{item.pagePath}}"
        data-index="{{index}}"
        bindtap="switchTab">
    <text class="tab-bar-text">{{item.text}}</text>
  </view>
</view>
